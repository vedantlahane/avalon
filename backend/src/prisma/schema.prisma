// This is your Prisma schema file,
generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth models
model User {
  id              String         @id @default(uuid())
  email           String         @unique
  name            String?
  isOnboarded     Boolean?       @default(false)
  role            String?
  teamSize        String?
  revenueTarget   Float?
  createdAt       DateTime       @default(now())
  identities      UserIdentity[]
  isDeleted       Boolean?

  @@index([email])
}

model UserIdentity {

  id         String   @id @default(uuid())

  userId     String

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider   String // 'Google', 'GitHub', 'EmailPassword', 'PhoneOTP', etc.

  providerId String // Provider's unique user ID (or email for email/password)

  metadata   Json? // Provider-specific data (passwordHash, tokens, profile data, etc.)

  createdAt  DateTime @default(now())

  updatedAt  DateTime @updatedAt

  isDeleted  Boolean?



  @@unique([provider, providerId])

  @@index([userId])

}





model Otp {

  id         String   @id @default(uuid())

  identifier String   // Phone number or email address

  type       String   // 'phone' or 'email'

  otp        String   // Hashed OTP

  expiresAt  DateTime

  attempts   Int      @default(0)

  verified   Boolean  @default(false)

  purpose    String?  // 'login', 'registration', 'password_reset', '2fa', etc.

  createdAt  DateTime @default(now())

  updatedAt  DateTime @updatedAt

  isDeleted  Boolean?



  @@index([identifier, type])

  @@index([expiresAt])

  @@index([identifier, type, verified])

}



model Contact {

  id              Int        @id @default(autoincrement())

  firstName       String

  lastName        String

  email           String     @unique

  phone           String?

  jobTitle        String?

  companyId       Int?

  company         Company?   @relation(fields: [companyId], references: [id])

  leadSource      String?    // Website, LinkedIn, Referral, Cold Outreach, Event, Advertisement, Other

  leadStatus      String?    // New, Contacted, Qualified, Unqualified, Nurturing

  leadScore       Int        @default(0)

  leadCategory    String?    // Hot, Warm, Cool, Cold, Unqualified

  demographicScore Int       @default(0)

  behavioralScore Int        @default(0)

  scoreBreakdown  Json?      // Detailed points breakdown

  scoreTrend      Int        @default(0)

  aiNote          String?

  scoreHistory    LeadScoreHistory[]

  tags            String[]   @default([])

  address         String?

    linkedinUrl     String?

    twitterUrl      String?

    website         String?

    notes           String?

    lastContacted   DateTime?

  

    owner           String     @default("Me")

    avatarUrl       String?

    activities      Activity[]

    tasks           Task[]

    deals           Deal[]

    emails          Email[]

    createdAt       DateTime   @default(now())

    updatedAt       DateTime   @updatedAt

    isDeleted       Boolean    @default(false)

  }

  

  model Email {

    id        Int      @id @default(autoincrement())

    sender    String

    senderName String?

    senderAvatar String?

    subject   String

    content   String

    timestamp DateTime @default(now())

    isRead    Boolean  @default(false)

    isStarred Boolean  @default(false)

    isAIFlagged Boolean @default(false)

    folder    String   @default("Inbox")

    contactId Int?

    contact   Contact? @relation(fields: [contactId], references: [id])

    dealId    Int?

    deal      Deal?    @relation(fields: [dealId], references: [id])

    summary   String?

    sentiment String?

    sentimentScore Int?

    attachments Json?

    keyPoints String[] @default([])

    intent    String?

    suggestedActions String[] @default([])

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    isDeleted Boolean  @default(false)

  }

  

  model Company {

  id           Int        @id @default(autoincrement())

  name         String

  domain       String?

  industry     String?    // Technology, Healthcare, Finance, Education, Retail, Manufacturing, Consulting, Real Estate, Other

  size         String?    // 1-10, 11-50, 51-200, 201-500, 501-1000, 1000+

  revenue      String?

  location     String?

  website      String?

    linkedinUrl  String?

    description  String?

    healthScore  Int?       @default(0)

    contacts     Contact[]

    deals        Deal[]

  createdAt    DateTime   @default(now())

  updatedAt    DateTime   @updatedAt

  isDeleted    Boolean    @default(false)

}



model Deal {

  id                Int        @id @default(autoincrement())

  name              String

  value             Float

  currency          String     @default("USD")

  stage             String     // Lead, Qualified, Discovery, Proposal, Negotiation, Closed Won, Closed Lost

  probability       Int?

  contactId         Int?

  contact           Contact?   @relation(fields: [contactId], references: [id])

  companyId         Int?

  company           Company?   @relation(fields: [companyId], references: [id])

  expectedCloseDate DateTime?

  actualCloseDate   DateTime?

    lossReason        String?

    priority          String     // Low, Medium, High, Critical

    notes             String?

    competitors       String[]   @default([])

    lineItems         LineItem[]

    owner             String     @default("Me")

    activities        Activity[]

    tasks             Task[]

    emails            Email[]

    createdAt         DateTime   @default(now())

    updatedAt         DateTime   @updatedAt

    isDeleted         Boolean    @default(false)

  }

  

  model LineItem {

    id          Int      @id @default(autoincrement())

    dealId      Int

    deal        Deal     @relation(fields: [dealId], references: [id])

    productName String

    quantity    Int

    unitPrice   Float

    total       Float

    createdAt   DateTime @default(now())

    updatedAt   DateTime @updatedAt

    isDeleted   Boolean  @default(false)

  }

  



model Activity {

  



  id              Int      @id @default(autoincrement())

  



  type            String   // Email, Call, Meeting, Note, Task, Demo, Follow-up

  



  title           String

  



  description     String?

  



  contactId       Int?

  



  contact         Contact? @relation(fields: [contactId], references: [id])

  



  dealId          Int?

  



  deal            Deal?    @relation(fields: [dealId], references: [id])

  



  date            DateTime @default(now())

  



  durationMinutes Int?

  



  outcome         String?  // Connected, Pending, Cancelled, No-show, etc.

  



  nextSteps       String?

  



  

  



  // New optional fields for enhanced activity logging

  



  sentiment       String?  // Positive, Neutral, Negative, Cautious

  



  metadata        Json?    // For type-specific fields like attendees, products, objections, etc.

  



  keyPoints       String[] @default([])

  



  aiSummary       String?

  



  

  



  createdAt       DateTime @default(now())

  



  updatedAt       DateTime @updatedAt

  



  isDeleted       Boolean  @default(false)

  



}

  







model Task {

  id          Int      @id @default(autoincrement())

  title       String

  description String?

  dueDate     DateTime?

  priority    String   // Low, Medium, High, Urgent

  status      String   // To Do, In Progress, Completed

  contactId   Int?

  contact     Contact? @relation(fields: [contactId], references: [id])

  dealId      Int?

  deal            Deal?    @relation(fields: [dealId], references: [id])

  aiGenerated Boolean  @default(false)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  isDeleted   Boolean  @default(false)

}



model EmailTemplate {
  id             Int      @id @default(autoincrement())
  name           String?
  subject        String?
  body           String?
  category       String?  // Follow-up, Introduction, Proposal, Thank You, Re-engagement, Custom
  aiGenerated    Boolean  @default(false)
  variablesCount Int      @default(0)
  usedCount      Int      @default(0)
  avgOpenRate    Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false)
}

model Notification {
  id                   Int      @id @default(autoincrement())
  type                 String   // AI, Deal, Task, Email, Contact, System
  title                String
  message              String
  isRead               Boolean  @default(false)
  timestamp            DateTime @default(now())
  link                 String?
  actionLabel          String?
  actionLink           String?
  secondaryActionLabel String?
  secondaryActionLink  String?
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  isDeleted            Boolean  @default(false)
}

model LeadScoreHistory {
  id          Int      @id @default(autoincrement())
  contactId   Int
  contact     Contact  @relation(fields: [contactId], references: [id])
  score       Int
  change      Int
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([contactId])
}
